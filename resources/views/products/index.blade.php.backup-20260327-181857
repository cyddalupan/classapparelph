                banner.textContent = '✅ JAVASCRIPT LOADED!';
                document.body.appendChild(banner);
                
                // Test 4: Add border to first box IMMEDIATELY
                var firstBox = document.getElementById('box-shirt');
                if (firstBox) {
                    firstBox.style.border = '3px solid red';
                    firstBox.style.backgroundColor = '#ff000020';
                }
                
                // Test 5: Add hover to all boxes
                var boxes = document.querySelectorAll('.category-box');
                boxes.forEach(function(box) {
                    box.onmouseover = function() {
                        this.style.border = '3px solid blue';
                        this.style.transform = 'scale(1.1)';
                    };
                    box.onmouseout = function() {
                        this.style.border = '';
                        this.style.transform = '';
                    };
                    box.onclick = function() {
                        boxes.forEach(function(b) {
                            b.style.border = '';
                            b.style.backgroundColor = '';
                        });
                        this.style.border = '3px solid green';
                        this.style.backgroundColor = '#00ff0020';
                    };
                });
                
                console.log('✅ ALL JAVASCRIPT TESTS PASSED!');
                
            } catch (error) {
                console.error('❌ JAVASCRIPT ERROR:', error);
                alert('❌ JAVASCRIPT ERROR: ' + error.message);
            }
        });
        
        // Original code below (will only run if above works)
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🎯 PRODUCT LIST JavaScript loading...');
            
            // Category selection - SAME AS INVENTORY ACTION
            const categoryBoxes = document.querySelectorAll('.category-box');
            
            // Category selection handler - SAME AS INVENTORY ACTION
            categoryBoxes.forEach(box => {
                box.addEventListener('click', function() {
                    // Remove selection from all boxes
                    categoryBoxes.forEach(b => {
                        b.classList.remove('selected');
                    });
                    
                    // Add selection to clicked box
                    this.classList.add('selected');
                    
                    // Get selected category
                    const category = this.getAttribute('data-category');
                    console.log('Selected category:', category);
                });
            });
            
            // AUTO-SELECT FIRST BOX (Shirt Products) ON LOAD - LIKE INVENTORY ACTION
            // Check if we're on /productlist route
            const isProductListRoute = window.location.pathname.includes('/productlist');
            
            if (isProductListRoute) {
